# The token lives here — never commit it.
.env

# The agent's scratch/output directory (bind-mounted at /work). Keep the folder,
# ignore its contents.
work/*
!work/.gitkeep

# Workspace snapshots (opossum ws) — copy-on-write clones of ./work, kept beside it.
.opossum-snapshots/

# Generated artifacts (e.g. the .mcp.json opossum writes for x-opossum-mcp-tools).
.opossum/
